<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.client.ui.RegisterController"
      stylesheets="@../css/style.css">

    <!-- ═══════════════════════════════════════
         PANNEAU GAUCHE — Branding
         ═══════════════════════════════════════ -->
    <VBox alignment="CENTER" spacing="22" prefWidth="320" minWidth="320"
          style="-fx-background-color: linear-gradient(to bottom, #128C7E, #054d44); -fx-padding: 50 40;">

        <StackPane alignment="CENTER">
            <Circle radius="54" fill="#0D7A6E"/>
            <Label text="💬" style="-fx-font-size: 50px;"/>
        </StackPane>

        <VBox spacing="8" alignment="CENTER">
            <Label text="AppMessagerie"
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Rejoignez votre équipe dès maintenant"
                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px;"
                   wrapText="true" textAlignment="CENTER"/>
        </VBox>

        <VBox spacing="12" style="-fx-padding: 10 0 0 0;">
            <Label text="En créant un compte vous pourrez :"
                   style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="→" style="-fx-text-fill: #25D366; -fx-font-weight: bold;"/>
                <Label text="Envoyer des messages instantanés"
                       style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="→" style="-fx-text-fill: #25D366; -fx-font-weight: bold;"/>
                <Label text="Consulter l'historique complet"
                       style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="→" style="-fx-text-fill: #25D366; -fx-font-weight: bold;"/>
                <Label text="Recevoir les messages manqués"
                       style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ═══════════════════════════════════════
         PANNEAU DROIT — Formulaire
         ═══════════════════════════════════════ -->
    <VBox alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS"
          style="-fx-background-color: white; -fx-padding: 50 60;">

        <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="340">
            <Label text="Créer un compte" styleClass="form-title"/>
            <Label text="Choisissez vos identifiants de connexion."
                   styleClass="form-subtitle"/>
        </VBox>

        <Region prefHeight="24"/>

        <VBox spacing="14" maxWidth="340">

            <!-- Username -->
            <VBox spacing="6">
                <Label text="NOM D'UTILISATEUR" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="minimum 3 caractères"
                           styleClass="field-input" maxWidth="Infinity"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="MOT DE PASSE" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               styleClass="field-input" maxWidth="Infinity"/>
            </VBox>

            <!-- Confirm -->
            <VBox spacing="6">
                <Label text="CONFIRMER LE MOT DE PASSE" styleClass="field-label"/>
                <PasswordField fx:id="confirmField" promptText="Répétez votre mot de passe"
                               styleClass="field-input" maxWidth="Infinity"/>
            </VBox>

            <!-- Error / Success -->
            <Label fx:id="errorLabel" text="" wrapText="true" maxWidth="Infinity"
                   styleClass="error-box" managed="false" visible="false"/>

            <Region prefHeight="4"/>

            <!-- Register button -->
            <Button fx:id="registerButton" text="Créer mon compte →" onAction="#handleRegister"
                    styleClass="btn-primary" maxWidth="Infinity"/>

        </VBox>

        <Region prefHeight="20"/>

        <!-- Login link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Déjà inscrit ?" styleClass="form-subtitle"/>
            <Button text="Se connecter" onAction="#goToLogin" styleClass="btn-link"/>
        </HBox>
    </VBox>
</HBox>
