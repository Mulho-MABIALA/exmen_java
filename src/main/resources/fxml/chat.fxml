<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.client.ui.ChatController"
            stylesheets="@../css/style.css"
            prefWidth="1050" prefHeight="680">

    <left>
        <VBox prefWidth="290" minWidth="250" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-header">
                <VBox HBox.hgrow="ALWAYS" spacing="1">
                    <Label fx:id="labelUtilisateurCourant" text="Utilisateur"
                           styleClass="sidebar-title"/>
                    <Label text="En ligne" style="-fx-text-fill: #00A884; -fx-font-size: 12px;"/>
                </VBox>
                <Button text="📴" onAction="#gererDeconnexion" styleClass="logout-btn">
                    <tooltip><Tooltip text="Se déconnecter"/></tooltip>
                </Button>
            </HBox>
            <HBox style="-fx-background-color: #F0F2F5; -fx-padding: 8 12 10 12;">
                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 20;
                             -fx-padding: 7 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);">
                    <Label text="🔍" style="-fx-font-size: 12px; -fx-text-fill: #8696A0;"/>
                    <Label text="Rechercher ou démarrer une discussion"
                           style="-fx-text-fill: #8696A0; -fx-font-size: 12px;"/>
                </HBox>
            </HBox>
            <Label text="UTILISATEURS" styleClass="section-label" maxWidth="Infinity"/>
            <ListView fx:id="listeVueUtilisateurs" VBox.vgrow="ALWAYS"
                      styleClass="list-view"
                      style="-fx-background-color: white;"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="chat-bg">
            <HBox fx:id="chatHeader" alignment="CENTER_LEFT" spacing="12"
                  styleClass="chat-header">
                <StackPane fx:id="avatarContact"
                           minWidth="42" maxWidth="42"
                           minHeight="42" maxHeight="42"/>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="labelDiscussionAvec" text="Sélectionnez un utilisateur"
                           styleClass="chat-name"/>
                    <Label fx:id="labelStatutDiscussion" text=""
                           styleClass="chat-status"/>
                </VBox>
                <Button text="⋮"
                        style="-fx-background-color: transparent; -fx-text-fill: #8696A0;
                               -fx-font-size: 20px; -fx-cursor: hand; -fx-border-color: transparent;
                               -fx-padding: 0 6;"/>
            </HBox>
            <ListView fx:id="listeVueMessages" VBox.vgrow="ALWAYS"
                      styleClass="list-view chat-bg"/>
            <HBox alignment="CENTER" spacing="10" styleClass="input-area">
                <Button text="😊"
                        style="-fx-background-color: transparent; -fx-font-size: 20px;
                               -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 4;"/>
                <TextField fx:id="champMessage"
                           promptText="Tapez un message…"
                           styleClass="message-input"
                           HBox.hgrow="ALWAYS"/>
                <Button text="➤" onAction="#gererEnvoi" styleClass="send-btn"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
